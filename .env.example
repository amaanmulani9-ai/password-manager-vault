# Copy to .env and fill with real secrets for production deployments.
ENV=production

# JWT signing secret (generate a strong random value)
JWT_SECRET=

# Fernet key (generate once and keep stable)
FERNET_KEY=

# Optional overrides
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DATABASE_URL=sqlite:////data/vault.db
