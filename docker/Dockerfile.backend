FROM python:3.12-slim

WORKDIR /app

# Install deps
COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY backend/ .

# Expose API port
EXPOSE 8000

# Generate a Fernet key on first run if not provided via env
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
